    },
    "Luka — Classify with Mistral": {
      "main": [[{ "node": "Parse Classification", "type": "main", "index": 0 }]]
    },
    "Parse Classification": {
      "main": [[{ "node": "Route by Category", "type": "main", "index": 0 }]]
    },
    "Route by Category": {
      "main": [
        [{ "node": "Notify Slack — Medical", "type": "main", "index": 0 }],
        [{ "node": "Notify Slack — Order", "type": "main", "index": 0 }],
        [{ "node": "Notify Slack — Business", "type": "main", "index": 0 }],
        [{ "node": "Auto Reply — FAQ", "type": "main", "index": 0 }],
        [{ "node": "Build Webhook Response", "type": "main", "index": 0 }]
      ]
    },
    "Build Webhook Response": {
      "main": [[{ "node": "Respond to Widget", "type": "main", "index": 0 }]]
    }
  },
  "settings": {
