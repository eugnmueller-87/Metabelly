# ── AI (EU-based, GDPR compliant) ────────────────────────────────────────────
MISTRAL_API_KEY=your_mistral_api_key_here

# ── Security ──────────────────────────────────────────────────────────────────
# Generate encryption key:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=your_fernet_key_here

# Generate API secret:
#   python -c "import secrets; print(secrets.token_hex(32))"
API_SECRET_KEY=your_secret_key_here

# Comma-separated IP ranges allowed to hit /webhook endpoints
# Gmail Pub/Sub IPs: 35.191.0.0/16,130.211.0.0/22
# Slack IPs: 3.90.27.17,3.223.42.113 (check Slack docs for full list)
ALLOWED_WEBHOOK_IPS=35.191.0.0/16,130.211.0.0/22

# ── Slack ─────────────────────────────────────────────────────────────────────
SLACK_BOT_TOKEN=xoxb-your-token
SLACK_SIGNING_SECRET=your_signing_secret

# ── Google Workspace (EU region) ─────────────────────────────────────────────
GOOGLE_CLIENT_ID=your_client_id
GOOGLE_CLIENT_SECRET=your_client_secret
GOOGLE_REFRESH_TOKEN=your_refresh_token

# ── Database (Supabase) ───────────────────────────────────────────────────────
# Find in: Supabase dashboard → Project Settings → Database → Connection string
# Use the "URI" format, replace [YOUR-PASSWORD] with your DB password
# Important: use port 5432 (direct), not 6543 (pooler) — asyncpg needs direct
DATABASE_URL=postgresql+asyncpg://postgres.[project-ref]:[password]@aws-0-eu-central-1.pooler.supabase.com:5432/postgres

# ── Calendly ─────────────────────────────────────────────────────────────────
CALENDLY_API_KEY=your_calendly_key

# ── App ───────────────────────────────────────────────────────────────────────
ENVIRONMENT=development
LOG_LEVEL=INFO

# ── Monitoring (Agency Dashboard) ────────────────────────────────────────────
# Identifies this app in the Grafana token/cost dashboard.
# Must match the client slug used when adding this app to agent-config.yml.
CLIENT_NAME=metabelly
